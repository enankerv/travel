# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service role key (required for scout quota; never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenCage Geocoding (optional; for map view location lookup)
# Get a key at https://opencagedata.com/
# Free tier: 2500 req/day, 1 req/sec
OPENCAGE_API_KEY=

# Scout API limits (optional; caps LLM cost per request)
# Max chars sent to LLM per scout. ~4 chars ≈ 1 token; default 9k ≈ 2.2k tokens.
# Set both for frontend (paste modal warning) and backend (truncation).
# NEXT_PUBLIC_SCOUT_MAX_INPUT_CHARS=9000
# SCOUT_MAX_INPUT_CHARS=9000
# Max scout requests per user per minute.
# SCOUT_RATE_LIMIT_PER_MIN=10
# Max concurrent scouts (crawl + LLM).
# SCOUT_MAX_CONCURRENT=10
