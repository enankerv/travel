# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service role key (required; never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM (required for scout / stay suggestions experiments)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: defaults to gemini-2.5-flash in experiment script, gemini-3.1-flash-lite-preview in scout
# GEMINI_MODEL=gemini-2.5-flash
# Board chat Google Search grounding: off | auto (default) | always
# auto = only when the message asks for URLs, booking, hours, etc.
# Grounding is billed separately from tokens — Gemini 2.5: ~$35/1k grounded
# prompts after free daily quota; Gemini 3: ~$14/1k search queries after 5k/mo free.
# BOARD_CHAT_GOOGLE_SEARCH=auto

# OpenCage Geocoding (optional; for map view location lookup)
# Get a key at https://opencagedata.com/
# Free tier: 2500 req/day, 1 req/sec
OPENCAGE_API_KEY=
# Per-user geocode caps (all geocode calls share one rate-limited entry point).
# GEOCODE_RATE_LIMIT_PER_MIN=5
# GEOCODE_MAX_PER_USER_PER_DAY=30

# Scout API limits (optional; caps LLM cost per request)
# Max chars sent to LLM per scout. ~4 chars ≈ 1 token; default 9k ≈ 2.2k tokens.
# Set both for frontend (paste modal warning) and backend (truncation).
# NEXT_PUBLIC_SCOUT_MAX_INPUT_CHARS=9000
# SCOUT_MAX_INPUT_CHARS=9000
# Max scout requests per user per minute.
# SCOUT_RATE_LIMIT_PER_MIN=10
# Max concurrent scouts (crawl + LLM).
# SCOUT_MAX_CONCURRENT=10

# Stripe (optional; for credit pack purchases)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
