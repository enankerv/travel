# Frontend env (Next.js) — this file lists every variable read under frontend/
# via process.env (see lib/supabase.ts, lib/api.ts, components/PasteFormContent.tsx,
# components/ScoutBookmarkletInfo.tsx).

# Supabase (required) — same project as backend; use the anon key (never the service role)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API (optional in dev — defaults to http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production site URL (required for OAuth redirectTo in production builds)
# In development, redirects use http://localhost:<port> automatically.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Dev: OAuth redirect port. Prefer this if you use a non-3000 port — client code only
# reliably sees NEXT_PUBLIC_* vars, not PORT.
# NEXT_PUBLIC_PORT=3000

# Optional: shell / host when starting Next (also read in supabase redirect on server)
# PORT=3000

# Optional: public app URL (e.g. bookmarklet / links); falls back to empty in code
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Scout paste UI — max characters warned/shown before send (optional; default 9000)
# Align with backend SCOUT_MAX_INPUT_CHARS if you set it there.
# NEXT_PUBLIC_SCOUT_MAX_INPUT_CHARS=9000

# Not set here — provided by Next/hosting: NODE_ENV, VERCEL_*, etc.
